# Terraform state files (contain sensitive AWS resource IDs)
*.tfstate
*.tfstate.*
*.tfstate.backup

# Terraform working directory
.terraform/
.terraform.lock.hcl

# Variables file (may contain secrets like access keys)
*.tfvars
*.tfvars.json

# Crash log files
crash.log
crash.*.log

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# CLI config
.terraformrc
terraform.rc

# OS files
.DS_Store
Thumbs.db
